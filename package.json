  "scripts": {
    "build:check": "vp check",
    "build:dev": "vp pack src/**/*.ts",
    "prebuild.old": "barrelsby -D -H -q -l all -d src -e test -e create-dist",
    "barro": "barro .barro.config.cjs --write",
    "clean": "rimraf -fr coverage dist tmp",
    "clean:real": "rimraf -fr coverage dist tmp \"src/**/index.ts\"",
    "check-exports": "attw --pack --profile strict --profile esm-only --ignore-rules=cjs-resolves-to-esm --ignore-rules=unexpected-module-syntax dist/",
    "dist": "vp run barro && vp run lint:check && vp run build:check && vp run format:check && vp run build:dev && vp run test:coverage && vp run dist:package.json",
    "dist:package.json": "node create-dist-package.json.js $npm_package_version > dist/package.json",
    "test": "vp test --run",
    "test:dev": "vp test --watch",
    "test:coverage": "vp test --run --silent --coverage",
    "format": "vp fmt src test",
    "format:check": "vp fmt  --check src test",
    "format:dist": "vp fmt 'dist'",
    "lint": "vp lint --fix src test",
    "lint:check": "vp lint src test",
    "prepare": "vp config"
  },
